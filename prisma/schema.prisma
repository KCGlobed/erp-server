generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String                    @id @default(cuid())
  email              String                    @unique
  passwordHash       String
  firstName          String
  lastName           String
  status             UserStatus                @default(ACTIVE)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  cohortId           String?
  classAttendances   ClassAttendance[]
  classesTaught      ClassSchedule[]
  enrollments        CourseEnrollment[]
  invigilations      ExamSchedule[]
  facultyCohorts     FacultyCohortAssignment[]
  facultyAssignments FacultyCourseAssignment[]
  attendanceRecords  StudentAttendanceRecord[]
  cohort             Cohort?                   @relation(fields: [cohortId], references: [id])
  directPermissions  UserPermission[]
  roles              UserRole[]
  experiences        Experience[]
  facultyProfile     FacultyProfile?
  refreshTokens      RefreshToken[]
  studentProfile     StudentProfile?
  logs               SystemLog[]
  eventFaculties     EventFaculty[]
}

model FacultyProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  middleName             String?
  gender                 Gender?
  profilePhotoUrl        String?
  profileBannerUrl       String?
  personalEmail          String?
  mobileNumber           String?
  alternateMobileNumber  String?
  emergencyContactName   String?
  emergencyContactNumber String?
  currentAddress         String?
  permanentAddress       String?
  experienceYears        Int?
  experienceDescription  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  dateOfBirth            DateTime?
  dateOfJoining          DateTime?
  isFresher              Boolean   @default(false)
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("faculty_profiles")
}

model Experience {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  organizationName String
  designation      String
  functionalArea   String
  fromDate         DateTime
  toDate           DateTime?
  isCurrentOrganization    Boolean   @default(false)
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model StudentProfile {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  mobileNumber               String?
  emergencyContactName       String?
  emergencyContactNumber     String?
  parentGuardianName         String?
  relationship               String?
  specifyRelationship        String?
  parentGuardianPhoneNumber  String?
  parentGuardianEmailId      String?
  profilePhotoUrl            String?
  profileBannerUrl           String?
  dateOfBirth                DateTime?
  gender                     Gender?
  nationality                String?
  state                      String?
  city                       String?
  pinCode                    String?
  completeAddress            String?
  class10YearOfPassing       String?
  class10GradeType           String?
  class10Score               String?
  class10MediumOfInstruction String?
  class12YearOfPassing       String?
  class12GradeType           String?
  class12Score               String?
  class12MediumOfInstruction String?
  ugStatus                   String?
  ugGradeType                String?
  ugScore                    String?
  ugInstitutionName          String?
  ugMediumOfInstruction      String?
  hasHigherQualification     Boolean   @default(false)
  higherQualification        String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  isFresher                  Boolean   @default(false)
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
  users       UserPermission[]
}

model UserPermission {
  userId       String
  permissionId String
  grantedBy    String?
  grantedAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@id([userId, permissionId])
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
}

model SystemLog {
  id         String   @id @default(cuid())
  userId     String?
  level      LogLevel @default(INFO)
  context    String?
  message    String
  stack      String?
  method     String?
  url        String?
  statusCode Int?
  duration   Int?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([context])
  @@index([createdAt])
  @@index([level])
  @@map("system_logs")
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_otps")
}

model Course {
  id             String                    @id @default(cuid())
  name           String
  code           String                    @unique
  description    String?
  duration       String
  numTrimesters  Int                       @default(3)
  status         CourseStatus              @default(ACTIVE)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  classSchedules ClassSchedule[]
  cohortCourses  CohortCourse[]
  enrollments    CourseEnrollment[]
  curriculums    Curriculum[]
  events         EventCourse[]
  facultyCourses FacultyCourseAssignment[]
}

model Curriculum {
  id            String         @id @default(cuid())
  courseId      String
  version       String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cohortCourses CohortCourse[]
  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subjects      Subject[]

  @@unique([courseId, version])
}

model Subject {
  id               String          @id @default(cuid())
  curriculumId     String
  name             String
  code             String
  trimester        Int
  credits          Int
  learningOutcomes String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  assessments      Assessment[]
  classSchedules   ClassSchedule[]
  examSchedules    ExamSchedule[]
  modules          Module[]
  sessionPlans     SessionPlan[]
  curriculum       Curriculum      @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
}

model Module {
  id          String   @id @default(cuid())
  subjectId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topics      Topic[]
}

model Topic {
  id          String   @id @default(cuid())
  moduleId    String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model SessionPlan {
  id          String   @id @default(cuid())
  subjectId   String
  week        Int
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Assessment {
  id        String         @id @default(cuid())
  subjectId String
  name      String
  type      AssessmentType
  maxMarks  Int
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Cohort {
  id             String                    @id @default(cuid())
  name           String                    @unique
  startDate      DateTime
  endDate        DateTime
  status         CohortStatus              @default(ACTIVE)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  classSchedules ClassSchedule[]
  cohortCourses  CohortCourse[]
  events         EventCohort[]
  examSchedules  ExamSchedule[]
  facultyCohorts FacultyCohortAssignment[]
  holidays       HolidayCohort[]
  students       User[]
}

model CohortCourse {
  cohortId     String
  courseId     String
  curriculumId String
  cohort       Cohort     @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id])

  @@id([cohortId, courseId])
}

model CourseEnrollment {
  userId     String
  courseId   String
  status     CourseStatus @default(ACTIVE)
  enrolledAt DateTime     @default(now())
  course     Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, courseId])
}

model FacultyCourseAssignment {
  userId     String
  courseId   String
  assignedAt DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, courseId])
}

model FacultyCohortAssignment {
  userId     String
  cohortId   String
  assignedAt DateTime @default(now())
  cohort     Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, cohortId])
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holiday {
  id             String          @id @default(cuid())
  name           String
  startDate      DateTime
  endDate        DateTime
  type           HolidayType
  visibleToRoles String[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  cohorts        HolidayCohort[]
}

model HolidayCohort {
  holidayId String
  cohortId  String
  cohort    Cohort  @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  holiday   Holiday @relation(fields: [holidayId], references: [id], onDelete: Cascade)

  @@id([holidayId, cohortId])
}

model AcademicEvent {
  id             String            @id @default(cuid())
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime
  type           AcademicEventType
  visibleToRoles String[]
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  cohorts        EventCohort[]
  courses        EventCourse[]
  faculties      EventFaculty[]
}

model EventCohort {
  eventId  String
  cohortId String
  cohort   Cohort        @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  event    AcademicEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([eventId, cohortId])
}

model EventCourse {
  eventId  String
  courseId String
  course   Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  event    AcademicEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([eventId, courseId])
}

model EventFaculty {
  eventId   String
  facultyId String
  event     AcademicEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  faculty   User          @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@id([eventId, facultyId])
}

model ExamSchedule {
  id            String         @id @default(cuid())
  subjectId     String
  cohortId      String
  date          DateTime
  startTime     DateTime
  endTime       DateTime
  room          String?
  type          AssessmentType
  invigilatorId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cohort        Cohort         @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  invigilator   User?          @relation(fields: [invigilatorId], references: [id])
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model ClassSchedule {
  id              String           @id @default(cuid())
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  courseId        String
  cohortId        String
  subjectId       String
  facultyId       String
  room            String
  topic           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  classAttendance ClassAttendance?
  cohort          Cohort           @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  faculty         User             @relation(fields: [facultyId], references: [id])
  subject         Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model ClassAttendance {
  id              String                    @id @default(cuid())
  classScheduleId String                    @unique
  date            DateTime
  facultyId       String
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  classSchedule   ClassSchedule             @relation(fields: [classScheduleId], references: [id], onDelete: Cascade)
  faculty         User                      @relation(fields: [facultyId], references: [id])
  records         StudentAttendanceRecord[]
}

model StudentAttendanceRecord {
  id                String           @id @default(cuid())
  classAttendanceId String
  studentId         String
  status            AttendanceStatus
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  classAttendance   ClassAttendance  @relation(fields: [classAttendanceId], references: [id], onDelete: Cascade)
  student           User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classAttendanceId, studentId])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum LeaveType {
  SICK
  CASUAL
  EARNED
  MATERNITY
  PATERNITY
  UNPAID
  OTHER
}

enum NotificationType {
  INFO
  WARNING
  ALERT
  SUCCESS
  REMINDER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CourseStatus {
  ACTIVE
  INACTIVE
}

enum CohortStatus {
  PLANNING
  ACTIVE
  COMPLETED
  INACTIVE
}

enum HolidayType {
  NATIONAL
  FESTIVAL
  INSTITUTION
  SEMESTER_BREAK
}

enum AcademicEventType {
  ORIENTATION
  WORKSHOP
  SEMINAR
  GUEST_LECTURE
  CONVOCATION
  FACULTY_MEETING
  OTHER
}

enum AssessmentType {
  MID_TERM
  FINAL
  VIVA
  PRACTICAL
  ASSIGNMENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}
